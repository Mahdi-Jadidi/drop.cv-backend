# Copy this file to .env.local for host development.
# Copy this file to .env.docker for Docker Compose, then change
# localhost URLs to Docker service names:
#   DATABASE_URL: localhost -> postgres
#   REDIS_URL: localhost -> redis
#   MINIO_ENDPOINT: localhost -> minio

PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://dropcv_user:your_password@localhost:5432/dropcv
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=dropcv-files
ANTHROPIC_API_KEY=your_claude_api_key
FRONTEND_URL=http://localhost:8080
COOKIE_DOMAIN=localhost
# Optional: set to a trusted http(s) endpoint that returns country/city JSON for analytics.
ANALYTICS_GEO_LOOKUP_URL=
