{
  "name": "dropcv-backend",
  "version": "0.1.0",
  "description": "Backend API skeleton for drop.cv resume hosting.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "dotenv -e .env.local -- nodemon server.js",
    "dev:docker": "docker compose up",
    "migrate": "node scripts/migrate.js",
    "test": "dotenv -e .env.local -- node tests/index.js",
    "test:health": "dotenv -e .env.local -- node tests/suites/health.js",
    "test:auth": "dotenv -e .env.local -- node tests/suites/auth.js",
    "test:revenue": "dotenv -e .env.local -- node --test --test-concurrency=1 tests/revenue-mvp.test.js tests/payment-security.db.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "fastify-plugin": "^6.0.0",
    "mammoth": "^1.9.1",
    "minio": "^8.0.5",
    "nodemailer": "^7.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "slugify": "^1.6.6",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "nodemon": "^3.1.9"
  }
}

